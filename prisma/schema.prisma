generator client {
  provider = "prisma-client-js"
    previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  category    String
  images      String[]
  brand       String
  description String
  stock       Int
  price       Decimal  @db.Decimal(12,2)
  rating      Decimal  @db.Decimal(12,3)
  numReviews  Int
  isFeatured  Boolean
  banner      String?
  createdAt   DateTime @default(now())
}